<launch>

  <!-- World -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch"/>

  <!-- Robot 1 -->
  <group ns="robot1">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot1"
          args="-urdf -model robot1 -x 0 -y 0 -z 0 -param robot_description"/>

    <node pkg="mesh_comm" type="mesh_node.py" name="mesh_node" output="screen"/>
  </group>

  <!-- Robot 2 -->
  <group ns="robot2">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot2"
          args="-urdf -model robot2 -x 0.5 -y 0 -z 0 -param robot_description"/>

    <node pkg="mesh_comm" type="mesh_node.py" name="mesh_node" output="screen"/>
  </group>

  <!-- Robot 3 -->
  <group ns="robot3">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot3"
          args="-urdf -model robot3 -x 0 -y 0.5 -z 0 -param robot_description"/>

    <node pkg="mesh_comm" type="mesh_node.py" name="mesh_node" output="screen"/>
  </group>

  <!-- Robot 4 -->
  <group ns="robot4">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_burger.urdf.xacro" />

    <node pkg="gazebo_ros" type="spawn_model" name="spawn_robot4"
          args="-urdf -model robot4 -x 0.5 -y 0.5 -z 0 -param robot_description"/>

    <node pkg="mesh_comm" type="mesh_node.py" name="mesh_node" output="screen"/>
  </group>

  <!-- Emergency Response Tower -->
  <group ns="tower">
      <node pkg="mesh_comm" type="tower_node.py" name="tower_node" output="screen"/>
  </group>
</launch>